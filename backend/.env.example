# ─── Open Source Mentee Agent — Backend Environment Variables ──────────────────
# Copy this file to .env and fill in your values.
# TRD §11.3 — all variables required in production.

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mentee_agent_db

# ─── Cache ───────────────────────────────────────────────────────────────────
# Redis connection string
REDIS_URL=redis://localhost:6379/0

# ─── AI Keys ─────────────────────────────────────────────────────────────────
# Gemini API key (required for all LLM and embedding calls)
GEMINI_API_KEY=your_gemini_api_key_here

# ─── GitHub ──────────────────────────────────────────────────────────────────
# Token pool: comma-separated list of PATs (≥1 required).
# Multiple tokens enable rate-limit rotation (TRD §7.1 — pool of ≥5 for prod).
GITHUB_TOKENS=ghp_token1,ghp_token2
# Legacy single-token fallback (if GITHUB_TOKENS is not set)
# GITHUB_TOKEN=ghp_your_token_here

# Webhook HMAC secret — set this in GitHub repo → Settings → Webhooks
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# GitHub OAuth App (for NextAuth frontend login)
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# ─── LLM Configuration ───────────────────────────────────────────────────────
# Primary model (default: gemini-2.0-flash)
LLM_MODEL=gemini-2.0-flash
# Fallback model used on quota/503 errors
LLM_FALLBACK_MODEL=gemini-1.5-flash
# Embedding model for duplicate detection
EMBEDDING_MODEL=text-embedding-004

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Chroma Vector Store ─────────────────────────────────────────────────────
# Path where Chroma persists embeddings (relative to backend working directory)
CHROMA_PATH=.chroma

# ─── Auth ────────────────────────────────────────────────────────────────────
# Set to True once GitHub OAuth is wired in the frontend (NextAuth)
AUTH_ENABLED=False

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Agent Limits (optional overrides) ───────────────────────────────────────
# MAX_TREE_ITEMS=200
# MAX_README_CHARS=1500
# MAX_ISSUE_BODY_CHARS=2000
# MAX_PR_FILES=20
# MAX_PR_PATCH_CHARS=500
# MAX_CODE_AGENT_TREE_ITEMS=300
# MAX_AFFECTED_FILES=10
# DUPLICATE_SIMILARITY_THRESHOLD=85
